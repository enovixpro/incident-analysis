# ===== REQUIRED — pick ONE of these two providers =====
# Option A: Anthropic direct
ANTHROPIC_API_KEY=sk-ant-...

# Option B: OpenRouter (overrides ANTHROPIC_API_KEY when set).
# Lets you use the Anthropic SDK against OpenRouter's Anthropic-compatible
# /messages endpoint — same protocol, same features (tool use, caching, thinking
# pass through when the underlying model supports them).
OPENROUTER_API_KEY=
OPENROUTER_MODEL=anthropic/claude-sonnet-4.5
# Optional headers shown in your OpenRouter dashboard:
OPENROUTER_REFERER=
OPENROUTER_TITLE=

# ===== OPTIONAL — Slack =====
# Leave blank to run in mock mode (logs payload, returns fake response)
SLACK_BOT_TOKEN=
SLACK_CHANNEL=#incidents

# ===== OPTIONAL — JIRA =====
# Leave any blank to run in mock mode
JIRA_URL=
JIRA_EMAIL=
JIRA_API_TOKEN=
JIRA_PROJECT_KEY=OPS

# ===== OPTIONAL — Tracing =====
# If set, LangGraph emits traces to LangSmith
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=incident-suite
LANGSMITH_TRACING=true

# ===== OPTIONAL — Model (only used when going via Anthropic direct) =====
# Defaults to claude-sonnet-4-5
ANTHROPIC_MODEL=claude-sonnet-4-5
